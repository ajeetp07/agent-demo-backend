{
  "TemplateName": "InviteUserTemplate",
  "SubjectPart": "You're Invited to Join Byldd – Set Up Your Account",
  "TextPart": "Hello {{name}}, You have been invited to join. Click here: {{inviteLink}}",
  "HtmlPart": "<!doctype html>\r\n<html lang=\"en\">\r\n  <head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n    <title>You're Invited to Join Byldd</title>\r\n    <style>\r\n      body {\r\n        margin: 0;\r\n        padding: 0;\r\n        background-color: #f4f4f4;\r\n        font-family: Arial, Helvetica, sans-serif;\r\n      }\r\n      .container {\r\n        max-width: 500px;\r\n        background-color: #ffffff;\r\n        margin: 40px auto;\r\n        padding: 30px 20px;\r\n        border-radius: 8px;\r\n        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\r\n        text-align: center;\r\n      }\r\n      h2 {\r\n        color: #333333;\r\n        margin-bottom: 20px;\r\n      }\r\n      p {\r\n        color: #555555;\r\n        font-size: 15px;\r\n        line-height: 1.6;\r\n        margin: 15px 0;\r\n      }\r\n      .btn {\r\n        display: inline-block;\r\n        background-color: #63cd32;\r\n        color: #ffffff !important;\r\n        text-decoration: none;\r\n        padding: 12px 24px;\r\n        font-weight: bold;\r\n        border-radius: 5px;\r\n        margin: 20px 0;\r\n        transition: background-color 0.3s ease;\r\n      }\r\n      .btn:hover {\r\n        background-color: #56b12c;\r\n      }\r\n      .link {\r\n        word-break: break-word;\r\n        color: #0066cc;\r\n        font-size: 14px;\r\n        margin: 15px 0;\r\n      }\r\n      .footer {\r\n        margin-top: 30px;\r\n        font-size: 12px;\r\n        color: #999999;\r\n        text-align: center;\r\n      }\r\n      .steps {\r\n        text-align: left;\r\n        margin: 20px 0;\r\n        padding-left: 20px;\r\n      }\r\n      .steps li {\r\n        margin-bottom: 10px;\r\n      }\r\n      .highlight-box {\r\n        background-color: #f8f9fa;\r\n        border-left: 4px solid #63cd32;\r\n        padding: 15px;\r\n        margin: 20px 0;\r\n        text-align: left;\r\n      }\r\n      .logo {\r\n        margin-bottom: 20px;\r\n        max-height: 50px;\r\n      }\r\n    </style>\r\n  </head>\r\n  <body>\r\n    <div class=\"container\">\r\n      <!-- Replace with your logo if available -->\r\n      <div class=\"logo\">\r\n        <strong style=\"font-size: 24px; color: #333\">Byldd</strong>\r\n      </div>\r\n\r\n      <h2>You're Invited!</h2>\r\n      <p>Hello <strong>{{name}}</strong>,</p>\r\n      <p>\r\n        You've been invited to join <strong>Byldd</strong> - the platform that\r\n        helps you build better.\r\n      </p>\r\n\r\n      <div class=\"highlight-box\">\r\n        <p>Here's what you'll need to do:</p>\r\n        <ol class=\"steps\">\r\n          <li>Click the button below to accept your invitation</li>\r\n          <li>Set up your account password</li>\r\n          <li>Verify your email with the OTP we'll send you</li>\r\n        </ol>\r\n      </div>\r\n\r\n      <a\r\n        href=\"{{inviteLink}}\"\r\n        class=\"btn\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\"\r\n      >\r\n        Accept Invitation\r\n      </a>\r\n\r\n      <p>\r\n        If the button doesn't work, copy and paste this link into your browser:\r\n      </p>\r\n      <p class=\"link\">{{inviteLink}}</p>\r\n\r\n      <p>\r\n        We're excited to have you on board! If you have any questions, reply to\r\n        this email.\r\n      </p>\r\n\r\n      <p style=\"margin-top: 30px\">\r\n        Best regards,<br />\r\n        <strong>The Byldd Team</strong>\r\n      </p>\r\n    </div>\r\n\r\n    <div class=\"footer\">\r\n      <p>&copy; 2025 Byldd. All rights reserved.</p>\r\n    </div>\r\n  </body>\r\n</html>\r\n",
  "TemplateFile": "invite-user.html"
}
