{
  "TemplateName": "ResetPasswordTemplate",
  "SubjectPart": "Reset Your Password",
  "TextPart": "Hello {{name}}, click the link to reset your password: {{resetLink}}",
  "HtmlPart": "<!doctype html>\r\n<html lang=\"en\">\r\n  <head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n    <title>Reset Your Password</title>\r\n    <style>\r\n      body {\r\n        margin: 0;\r\n        padding: 0;\r\n        background-color: #f4f4f4;\r\n        font-family: Arial, Helvetica, sans-serif;\r\n      }\r\n      .container {\r\n        max-width: 500px;\r\n        background-color: #ffffff;\r\n        margin: 40px auto;\r\n        padding: 30px 20px;\r\n        border-radius: 8px;\r\n        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\r\n        text-align: center;\r\n      }\r\n      h2 {\r\n        color: #333333;\r\n        margin-bottom: 20px;\r\n      }\r\n      p {\r\n        color: #555555;\r\n        font-size: 15px;\r\n        line-height: 1.6;\r\n      }\r\n      .btn {\r\n        display: inline-block;\r\n        background-color: #63cd32;\r\n        color: #ffffff !important;\r\n        text-decoration: none;\r\n        padding: 12px 24px;\r\n        font-weight: bold;\r\n        margin: 20px 0;\r\n        transition: background-color 0.3s ease;\r\n      }\r\n      .btn:hover {\r\n        background-color: #56b12c;\r\n      }\r\n      .link {\r\n        word-break: break-word;\r\n        color: #0066cc;\r\n        font-size: 14px;\r\n      }\r\n      .footer {\r\n        margin-top: 30px;\r\n        font-size: 12px;\r\n        color: #999999;\r\n        text-align: center;\r\n      }\r\n    </style>\r\n  </head>\r\n  <body>\r\n    <div class=\"container\">\r\n      <h2>Reset Your Password</h2>\r\n      <p>Hello <strong>{{name}}</strong>,</p>\r\n      <p>\r\n        We received a request to reset your password. Click the button below to\r\n        set a new one.\r\n      </p>\r\n      <a\r\n        href=\"{{resetLink}}\"\r\n        class=\"btn\"\r\n        target=\"_blank\"\r\n        rel=\"noopener noreferrer\"\r\n      >\r\n        Reset Password\r\n      </a>\r\n      <p>\r\n        If the button doesn't work, copy and paste this link into your browser:\r\n      </p>\r\n      <p class=\"link\">{{resetLink}}</p>\r\n    </div>\r\n    <div class=\"footer\">\r\n      <p>&copy; 2025 Byldd. All rights reserved.</p>\r\n    </div>\r\n  </body>\r\n</html>\r\n",
  "TemplateFile": "reset-password.html"
}
