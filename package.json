{
  "name": "boilerplate-backend",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node scripts/verifyEnvBackEnd && nodemon",
    "cron-dev": "cross-env NODE_ENV=development node scripts/verifyEnvBackEnd && nodemon -r tsconfig-paths/register src/cron/index.ts",
    "build:dev": "cross-env NODE_ENV=development node scripts/verifyEnvBackEnd.js && tsc -p tsconfig.build.json && tsc-alias",
    "build": "node scripts/verifyEnvBackEnd.js && tsc -p tsconfig.build.json && tsc-alias",
    "start": "node server/server.js",
    "cron-start": "node server/cron/index.js",
    "lint": "eslint .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "ses-push": "ts-node -r tsconfig-paths/register src/providers/email/templates/index.ts",
    "postinstall": "husky",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18.0.0 <=22"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.583.0",
    "@aws-sdk/client-ses": "^3.863.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@elastic/elasticsearch": "^8.17.1",
    "@langchain/core": "^0.3.19",
    "@langchain/openai": "^0.6.15",
    "@onesignal/node-onesignal": "^5.2.1-beta1",
    "@pinecone-database/pinecone": "^5.1.1",
    "@workos-inc/node": "^8.3.1",
    "axios": "^1.13.2",
    "cohere-ai": "^7.16.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.19",
    "lint-staged": "^16.2.7",
    "mammoth": "^1.9.0",
    "mime-types": "^2.1.35",
    "mongoose": "^8.4.0",
    "node-2fa": "^2.0.3",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "socket.io": "^4.8.1",
    "stream-chat": "^8.60.0",
    "stripe": "^15.12.0",
    "twilio": "^5.0.4",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.4",
    "zod-express-validator": "^0.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^9.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-status": "^0.2.30",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.7.7",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/stripe": "^8.0.417",
    "@types/stripe-v3": "^3.1.33",
    "@types/supertest": "^6.0.2",
    "@types/yargs": "^17.0.35",
